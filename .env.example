# ============================================
# AOS E-COMMERCE v2.0 - ENVIRONMENT CONFIG
# ============================================
# IMPORTANT: Yeh file kabhi bhi GitHub pe mat daalo!
# Render pe jao -> Environment -> Add below variables

# ----- SERVER -----
PORT=3000
NODE_ENV=production

# ----- MONGODB -----
# Apna MongoDB Atlas connection string daalo
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DBNAME
MONGODB_URI=mongodb+srv://vaibhavgupta2542_db_user:Raghav12321@aos.jctvpvu.mongodb.net/aos_ecommerce?retryWrites=true&w=majority

# ----- JWT SECRET -----
# Koi bhi random strong string daalo (min 32 chars)
# Example: openssl rand -base64 32
JWT_SECRET=aos-super-secret-jwt-key-change-this-in-production-2025

# ----- ADMIN CREDENTIALS -----
# Admin login ke liye (admin.html pe use hoga)
ADMIN_EMAIL=vaibhavgupta2542@gmail.com
ADMIN_PASSWORD=Admin@AOS2025

# ----- EMAIL CONFIG (Gmail SMTP) -----
# Gmail App Password banana ke liye:
# Google Account -> Security -> 2FA ON -> App Passwords -> Generate
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=ytlg yjis cqzf ekmo
# Jis email pe orders aayenge (tumhara personal/business email)
STORE_EMAIL=vaibhavgupta2542@gmail.com

# ----- WHATSAPP (Twilio) -----
# Option 1: Twilio WhatsApp (Free trial available)
# twilio.com pe account banao -> Console -> Account SID & Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio WhatsApp sandbox number (trial: +14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Tumhara WhatsApp number (country code ke saath)
OWNER_WHATSAPP=whatsapp:+919919917791

# ----- CORS -----
CLIENT_URL=https://aos-4jq4.onrender.com
CORS_ORIGIN=https://aos-4jq4.onrender.com

# ----- RATE LIMITING -----
RATE_LIMIT_WINDOW=900000
